generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                  String           @id @default(cuid())
  name                String           @default("عبد العزيز")
  level               Int              @default(1)
  xp                  Int              @default(0)
  xpToNextLevel       Int              @default(100)
  title               String           @default("مبتدئ")
  currentStreak       Int              @default(0)
  longestStreak       Int              @default(0)
  totalTasksCompleted Int              @default(0)
  sessionToken        String?
  lastActiveDate      DateTime?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  account             Account?
  tasks               Task[]
  habits              Habit[]
  goals               Goal[]
  moodLogs            MoodLog[]
  transactions        Transaction[]
  memories            AIMemory[]
  conversations       AIConversation[]
  agentTasks          AgentTask[]
  agentLogs           AgentLog[]
  settings            Setting?
  atsComponents       ATSComponent[]
  atsIssues           ATSIssue[]
  tawjihiSubjects     TawjihiSubject[]
  studySessions       StudySession[]
  chineseWords        ChineseWord[]
  notes               Note[]
  sleepLogs           SleepLog[]
  gratitudes          Gratitude[]
  capsules            TimeCapsule[]
  achievements        UserAchievement[]
}

model Account {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
}

model Task {
  id           String    @id @default(cuid())
  userId       String
  title        String
  description  String?
  status       String    @default("pending")
  priority     String    @default("medium")
  category     String?
  dueDate      DateTime?
  completedAt  DateTime?
  xpReward     Int       @default(15)
  createdAt    DateTime  @default(now())
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
}

model Habit {
  id               String            @id @default(cuid())
  userId           String
  name             String
  icon             String            @default("⭕")
  color            String            @default("#388BFD")
  streak           Int               @default(0)
  bestStreak       Int               @default(0)
  totalCompletions Int               @default(0)
  xpPerCompletion  Int               @default(10)
  isActive         Boolean           @default(true)
  createdAt        DateTime          @default(now())
  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  completions      HabitCompletion[]

  @@index([userId])
}

model HabitCompletion {
  id        String   @id @default(cuid())
  habitId   String
  date      DateTime
  completed Boolean  @default(false)
  xpEarned  Int      @default(0)
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
}

model Goal {
  id         String    @id @default(cuid())
  userId     String
  title      String
  category   String    @default("personal")
  progress   Int       @default(0)
  status     String    @default("active")
  targetDate DateTime?
  createdAt  DateTime  @default(now())
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  milestones Milestone[]

  @@index([userId])
}

model Milestone {
  id        String   @id @default(cuid())
  goalId    String
  title     String
  completed Boolean  @default(false)
  goal      Goal     @relation(fields: [goalId], references: [id], onDelete: Cascade)
}

model MoodLog {
  id        String   @id @default(cuid())
  userId    String
  mood      Int
  energy    Int?
  stress    Int?
  note      String?
  date      DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String
  type        String
  amount      Float
  category    String
  description String?
  date        DateTime
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIMemory {
  id         String   @id @default(cuid())
  userId     String
  type       String
  content    String
  importance Int      @default(3)
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AIConversation {
  id        String   @id @default(cuid())
  userId    String
  role      String
  content   String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AgentTask {
  id        String      @id @default(cuid())
  userId    String
  title     String
  status    String      @default("pending")
  type      String      @default("general")
  result    String?
  createdAt DateTime    @default(now())
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs      AgentLog[]

  @@index([userId])
}

model AgentLog {
  id        String    @id @default(cuid())
  taskId    String
  userId    String
  type      String
  content   String
  createdAt DateTime  @default(now())
  task      AgentTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model Setting {
  id           String   @id @default(cuid())
  userId       String   @unique
  savingsGoal  Float    @default(26000)
  tawjihiDate  String   @default("2026-06-15")
  chinaDate    String   @default("2026-09-01")
  notifications Boolean @default(true)
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model ATSComponent {
  id        String   @id @default(cuid())
  userId    String
  name      String
  type      String
  status    String   @default("pending")
  notes     String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ATSIssue {
  id          String   @id @default(cuid())
  userId      String
  title       String
  description String?
  solution    String?
  status      String   @default("open")
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TawjihiSubject {
  id             String         @id @default(cuid())
  userId         String
  name           String
  studyHours     Float          @default(0)
  targetHours    Float          @default(40)
  reviewProgress Int            @default(0)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessions       StudySession[]

  @@index([userId])
}

model StudySession {
  id        String           @id @default(cuid())
  userId    String
  subjectId String
  hours     Float
  date      DateTime
  notes     String?
  subject   TawjihiSubject   @relation(fields: [subjectId], references: [id])
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ChineseWord {
  id            String   @id @default(cuid())
  userId        String
  chinese       String
  pinyin        String
  arabic        String
  hskLevel      Int      @default(1)
  timesReviewed Int      @default(0)
  mastered      Boolean  @default(false)
  addedAt       DateTime @default(now())
  lastReviewed  DateTime?
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  title     String
  content   String
  pinned    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model SleepLog {
  id       String   @id @default(cuid())
  userId   String
  bedtime  DateTime
  wakeTime DateTime
  quality  Int
  date     DateTime
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
}

model Gratitude {
  id        String   @id @default(cuid())
  userId    String
  text      String
  date      DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model TimeCapsule {
  id        String   @id @default(cuid())
  userId    String
  message   String
  openDate  DateTime
  opened    Boolean  @default(false)
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Achievement {
  id               String            @id @default(cuid())
  name             String
  description      String
  icon             String
  xpReward         Int
  type             String
  requirement      Int
  userAchievements UserAchievement[]
}

model UserAchievement {
  id            String      @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime    @default(now())
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id])
}
